{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/PolicyVault/templates/main/schemas/template-catalog-entry.schema.json",
  "title": "PolicyVault Azure DevOps template catalog entry",
  "description": "Schema for PolicyVault work-item query policy templates stored in this repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "source",
    "policy"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "policyvault.io/v1"
    },
    "kind": {
      "type": "string",
      "const": "WorkItemQueryPolicy"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "description",
        "tags"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Template identifier used by catalog tooling."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "queryName",
        "query"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "const": "azure-devops"
        },
        "queryName": {
          "type": "string",
          "minLength": 1
        },
        "query": {
          "type": "string",
          "minLength": 1,
          "description": "WIQL query text."
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rules",
        "severity",
        "action"
      ],
      "properties": {
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "description",
              "mustBeInQueryResults"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "mustBeInQueryResults": {
                "type": "boolean"
              }
            }
          }
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "warn",
            "block"
          ]
        }
      }
    }
  }
}
